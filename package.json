{
  "name": "stenographer-mode",
  "version": "0.1.0",
  "private": false,
  "description": "Steno Mode — GitHub Copilot prompt pack and custom agent for ~40% token reduction. Works with VS Code Copilot, Claude Code, Kiro, ChatGPT, Cursor.",
  "author": "Akash Dwivedi",
  "license": "MIT",
  "keywords": [
    "steno mode",
    "stenographer mode",
    "steno mode github copilot",
    "github copilot prompt pack",
    "github copilot custom agent",
    "steno",
    "stenographer",
    "prompt",
    "prompt engineering",
    "token reduction",
    "token optimization",
    "ai token optimization",
    "llm cost optimization",
    "prompt compression",
    "claude code",
    "kiro",
    "windsurf",
    "aider",
    "cody",
    "ai coding assistant",
    "token saving",
    "vscode",
    "github copilot",
    "chatgpt",
    "claude",
    "cursor",
    "custom agent"
  ],
  "homepage": "https://akashai7.github.io/stenographer-mode/demo/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkashAi7/stenographer-mode.git"
  },
  "bugs": {
    "url": "https://github.com/AkashAi7/stenographer-mode/issues"
  },
  "type": "module",
  "bin": {
    "steno-mode": "./scripts/steno-mode.mjs"
  },
  "files": [
    ".github/agents/",
    ".github/skills/",
    "benchmarks/",
    "bundles/",
    "demo/",
    "install/",
    "packs/",
    "scripts/",
    "README.md",
    "bundle.json",
    "product.json",
    "release.json"
  ],
  "scripts": {
    "benchmark": "node ./scripts/generate-benchmarks.mjs",
    "install:user": "node ./scripts/steno-mode.mjs install --scope user",
    "install:project": "node ./scripts/steno-mode.mjs install --scope project",
    "convert:github:preview": "node ./scripts/steno-mode.mjs convert-github --mode preview --project-dir .",
    "convert:github:apply": "node ./scripts/steno-mode.mjs convert-github --mode apply --project-dir .",
    "uninstall:user": "node ./scripts/steno-mode.mjs uninstall --scope user",
    "uninstall:project": "node ./scripts/steno-mode.mjs uninstall --scope project"
  },
  "dependencies": {
    "gpt-tokenizer": "^3.4.0"
  }
}